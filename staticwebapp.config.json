{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/api/*", "/logo.png", "*.{png,jpg,gif,ico,svg}"]
  },
  "routes": [
    {
      "route": "/api/*",
      "allowedRoles": ["anonymous"]
    }
  ],
  "responseOverrides": {
    "404": {
      "rewrite": "/index.html"
    }
  }
}
